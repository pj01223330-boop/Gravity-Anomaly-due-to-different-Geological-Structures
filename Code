def run_synthetic(outdir=r"C:\Users\ripun\Downloads"):
    """Interactive synthetic-terrain mode."""
    print("\n" + "-" * 60)
    print("  SYNTHETIC TERRAIN TYPES")
    print("-" * 60)
    for k, v in TerrainGenerator.TERRAIN_TYPES.items():
        print(f"  [{k}] {v}")
    print("  [A] All terrains (batch run)")
    print("-" * 60)

    choice  = _ask("Terrain choice", "1")
    all_keys = list(TerrainGenerator.TERRAIN_TYPES.keys())

    if choice.upper() == "A":
        choices = all_keys
    elif choice in TerrainGenerator.TERRAIN_TYPES:
        choices = [choice]
    else:
        print(f"  Unknown choice '{choice}'.  Defaulting to terrain 1.")
        choices = ["1"]

    nx      = _ask_int  ("Grid size (nx = ny)", 128)
    dx      = _ask_float("Grid spacing dx = dy [m]", 1000.0)
    z_km    = _ask_float("Upward continuation altitude [km]", 5.0)
    z_alt   = z_km * 1e3
    meth    = _ask_method()
    omega   = 1.0 if meth == "jacobi" else _ask_float(
        "SOR omega (0 < ω < 2, ~1.7–1.9 for large grids)", 1.7)
    nz      = _ask_int  ("FD vertical levels nz", 60)
    tol_str = _ask("FD convergence tolerance", "1e-5")
    try:
        tol = float(tol_str)
    except ValueError:
        tol = 1e-5
    mxiter  = _ask_int("FD maximum iterations", 6000)

    summary = []

    for tc in choices:
        if tc not in TerrainGenerator.TERRAIN_TYPES:
            print(f"  Skipping unknown terrain key '{tc}'")
            continue

        tname = TerrainGenerator.TERRAIN_TYPES[tc]
        print(f"\n{'=' * 60}")
        print(f"  TERRAIN: {tname}")
        print(f"{'=' * 60}")

        # Generate terrain + surface gravity
        gen  = TerrainGenerator(nx=nx, ny=nx, dx=dx, dy=dx)
        topo, rho = gen.generate(tc)

        print("  Computing Bouguer surface gravity ...")
        surf = bouguer_gravity(topo, rho)

        print("  Fourier 2-D upward continuation ...")
        fs   = FourierSolver(dx=dx, dy=dx)
        f2d  = fs.upward_continue_2d(surf, z_alt)

        # 1-D FD comparison on central profile
        comp = run_comparison(
            surf[nx // 2, :], dx=dx, z_target=z_alt,
            fd_nz=nz, fd_tol=tol, fd_omega=omega,
            fd_method=meth, fd_max_iter=mxiter,
        )

        tag  = tname[:20].replace(" ", "_")
        out  = os.path.join(outdir, f"gravity_{tc}_{tag}.png")
        plot_synthetic(topo, surf, f2d, comp, tname, z_alt, dx, outpath=out)

        summary.append((tname, comp["rms_err"], comp["max_err"],
                        comp["rel_pct"], comp["t_fd"]))

    # Print summary table for batch runs
    if len(summary) > 1:
        print(f"\n{'=' * 70}")
        print("  BATCH SUMMARY")
        print(f"  {'Terrain':<40} {'RMS':>8} {'Max':>8} {'Rel%':>7} {'FD(s)':>7}")
        print(f"  {'-' * 40} {'-' * 8} {'-' * 8} {'-' * 7} {'-' * 7}")
        for tname, rms, mx, rel, tfd in summary:
            print(f"  {tname:<40} {rms:8.3f} {mx:8.3f} {rel:7.2f} {tfd:7.2f}")
        print(f"{'=' * 70}")



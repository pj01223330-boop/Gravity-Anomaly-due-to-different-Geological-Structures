def _add_colorbar(fig, ax, im, label):
    c = fig.colorbar(im, ax=ax, shrink=0.82, pad=0.02)
    c.set_label(label, fontsize=9)


def plot_synthetic(topo, surface_grav, fourier_2d, comp,
                   terrain_name, z_alt, dx, outpath=None):
    """
    Six-panel diagnostic figure for a synthetic terrain run.

    Row 0:  topography | surface gravity | Fourier 2-D upward continued
    Row 1:  FD vs Fourier profile | FD 2-D field | convergence history
    """
    ny, nx = surface_grav.shape
    extent = [0, nx * dx / 1e3, 0, ny * dx / 1e3]
    mid    = ny // 2
    x_km   = np.arange(nx) * dx / 1e3

    fig = plt.figure(figsize=(21, 11))
    fig.suptitle(
        f"Gravity Anomaly Pipeline  —  {terrain_name}\n"
        f"Upward continuation  z = {z_alt / 1e3:.1f} km  |  "
        f"grid {nx}×{ny},  Δx = {dx / 1e3:.2f} km",
        fontsize=13, fontweight="bold", y=0.99,
    )
    gs = gridspec.GridSpec(
        2, 3, figure=fig,
        hspace=0.45, wspace=0.38,
        left=0.06, right=0.97, top=0.92, bottom=0.07,
    )

    # Panel 1 — Topography
    ax = fig.add_subplot(gs[0, 0])
    im = ax.imshow(topo, origin="lower", cmap="terrain",
                   extent=extent, aspect="auto")
    ax.set_title("Geological Structure / Topography", fontsize=10, pad=4)
    ax.set_xlabel("X (km)", fontsize=9)
    ax.set_ylabel("Y (km)", fontsize=9)
    _add_colorbar(fig, ax, im, "Height / Thickness (m)")

    # Panel 2 — Surface gravity
    ax = fig.add_subplot(gs[0, 1])
    vmax = np.nanpercentile(np.abs(surface_grav), 99)
    im = ax.imshow(surface_grav, origin="lower", cmap="seismic",
                   extent=extent, vmin=-vmax, vmax=vmax, aspect="auto")
    ax.axhline(mid * dx / 1e3, color="k", lw=1.5, ls="--",
               label=f"Profile (row {mid})")
    ax.set_title("Surface Bouguer Gravity  (z = 0)", fontsize=10, pad=4)
    ax.set_xlabel("X (km)", fontsize=9)
    ax.set_ylabel("Y (km)", fontsize=9)
    ax.legend(fontsize=8, loc="upper right")
    _add_colorbar(fig, ax, im, "mGal")

    # Panel 3 — Fourier 2-D upward continued
    ax = fig.add_subplot(gs[0, 2])
    vuc = np.nanpercentile(np.abs(fourier_2d), 99)
    im = ax.imshow(fourier_2d, origin="lower", cmap="seismic",
                   extent=extent, vmin=-vuc, vmax=vuc, aspect="auto")
    ax.set_title(f"Fourier Upward Continued  (z = {z_alt / 1e3:.1f} km)",
                 fontsize=10, pad=4)
    ax.set_xlabel("X (km)", fontsize=9)
    ax.set_ylabel("Y (km)", fontsize=9)
    _add_colorbar(fig, ax, im, "mGal")

    # Panel 4 — Profile comparison  (spans two columns)
    ax = fig.add_subplot(gs[1, :2])
    surf_p = surface_grav[mid, :]
    ax.plot(x_km, surf_p,
            color="silver", lw=1.5, zorder=1,
            label="Surface  (z = 0)")
    ax.plot(x_km, comp["fourier"],
            color="#1f77b4", lw=2.2, zorder=3,
            label=f"Fourier  (z = {z_alt / 1e3:.1f} km)")
    ax.plot(x_km, comp["fd"],
            color="#d62728", lw=2.0, ls="--", zorder=4,
            label=f"FD {comp['method'].replace('_', '-')}  "
                  f"(z = {z_alt / 1e3:.1f} km)")
    ax.fill_between(x_km, comp["fourier"], comp["fd"],
                    color="#2ca02c", alpha=0.25, zorder=2,
                    label="FD − Fourier  difference")
    ax.set_title("Central Profile  —  FD vs Fourier Comparison",
                 fontsize=10, pad=4)
    ax.set_xlabel("X (km)", fontsize=9)
    ax.set_ylabel("Gravity Anomaly (mGal)", fontsize=9)
    ax.legend(fontsize=9, loc="upper right")
    ax.grid(True, alpha=0.3, lw=0.6)

    stats = (
        f"RMS error : {comp['rms_err']:.3f} mGal\n"
        f"Max error : {comp['max_err']:.3f} mGal\n"
        f"Relative  : {comp['rel_pct']:.2f}%\n"
        f"Fourier   : {comp['t_fourier'] * 1e3:.1f} ms\n"
        f"FD        : {comp['t_fd']:.2f} s\n"
        f"ω = {comp['omega']:.2f},  tol = {comp['tol']:.0e}"
    )
    ax.text(0.01, 0.97, stats, transform=ax.transAxes,
            fontsize=8, va="top", ha="left",
            bbox=dict(boxstyle="round,pad=0.4",
                      fc="lightyellow", ec="goldenrod", alpha=0.92))

    # Panel 5 — Convergence history
    ax = fig.add_subplot(gs[1, 2])
    iters = np.arange(1, len(comp["residuals"]) + 1)
    ax.semilogy(iters, comp["residuals"], color="#d62728", lw=1.5)
    ax.axhline(comp["tol"], color="gray", ls=":", lw=1.2,
               label=f"tol = {comp['tol']:.0e}")
    ax.set_title("FD Solver Convergence History", fontsize=10, pad=4)
    ax.set_xlabel("Iteration", fontsize=9)
    ax.set_ylabel("max |ΔΦ| (mGal)", fontsize=9)
    ax.legend(fontsize=9)
    ax.grid(True, alpha=0.3, lw=0.6)

    _save_figure(fig, outpath)


def plot_real_data(result, outpath=None):
    """Four-panel diagnostic figure for real NetCDF data."""
    lon   = result["lon"]
    lat   = result["lat"]
    mid   = result["mid_row"]
    z_alt = result["z_alt"]
    dx    = result["dx"]
    comp  = result["comp"]
    x_km  = np.arange(len(comp["fourier"])) * dx / 1e3

    fig, axes = plt.subplots(2, 2, figsize=(16, 10))
    fig.suptitle(
        f"Real Data  '{result['var_name']}'  |  "
        f"Upward continuation {z_alt / 1e3:.1f} km",
        fontsize=13, fontweight="bold",
    )

    ax = axes[0, 0]
    vmax = np.nanpercentile(np.abs(result["surface"]), 98)
    im = ax.pcolormesh(lon, lat, result["surface"],
                       cmap="seismic", vmin=-vmax, vmax=vmax, shading="auto")
    ax.axhline(lat[mid], color="k", ls="--", lw=1.5, label="Profile")
    ax.set_title("Original Surface Gravity  (z = 0)", fontsize=11)
    ax.set_xlabel("Longitude"); ax.set_ylabel("Latitude")
    ax.legend(fontsize=9)
    fig.colorbar(im, ax=ax, label="mGal", shrink=0.85)

    ax = axes[0, 1]
    vuc = np.nanpercentile(np.abs(result["fourier_2d"]), 98)
    im2 = ax.pcolormesh(lon, lat, result["fourier_2d"],
                        cmap="seismic", vmin=-vuc, vmax=vuc, shading="auto")
    ax.set_title(f"Fourier Upward Continued  ({z_alt / 1e3:.1f} km)", fontsize=11)
    ax.set_xlabel("Longitude"); ax.set_ylabel("Latitude")
    fig.colorbar(im2, ax=ax, label="mGal", shrink=0.85)

    ax = axes[1, 0]
    ax.plot(x_km, result["surface"][mid, :],
            color="silver", lw=1.5, label="Surface  z = 0")
    ax.plot(x_km, comp["fourier"],
            color="#1f77b4", lw=2.2,
            label=f"Fourier  z = {z_alt / 1e3:.1f} km")
    ax.plot(x_km, comp["fd"],
            color="#d62728", lw=2.0, ls="--",
            label=f"FD {comp['method'].replace('_', '-')}")
    ax.fill_between(x_km, comp["fourier"], comp["fd"],
                    color="#2ca02c", alpha=0.25, label="Difference")
    ax.set_title("Central Profile  —  FD vs Fourier", fontsize=11)
    ax.set_xlabel("Distance (km)"); ax.set_ylabel("Gravity (mGal)")
    ax.legend(fontsize=9); ax.grid(True, alpha=0.3)

    ax = axes[1, 1]
    ax.semilogy(np.arange(1, len(comp["residuals"]) + 1),
                comp["residuals"], color="#d62728", lw=1.5)
    ax.axhline(comp["tol"], color="gray", ls=":", lw=1.2,
               label=f"tol = {comp['tol']:.0e}")
    ax.set_title("FD Convergence", fontsize=11)
    ax.set_xlabel("Iteration"); ax.set_ylabel("max|ΔΦ| (mGal)")
    ax.legend(fontsize=9); ax.grid(True, alpha=0.3)

    fig.tight_layout(rect=[0, 0, 1, 0.95])
    _save_figure(fig, outpath)


def _save_figure(fig, outpath):
    """Save figure to outpath and display it inline."""
    os.makedirs(os.path.dirname(outpath) if os.path.dirname(outpath) else ".",
                exist_ok=True)
    plt.savefig(outpath, dpi=150, bbox_inches="tight")
    print(f"\n  Figure saved  →  {outpath}")
    plt.close(fig)

    # Display inline in Jupyter
    from IPython.display import display, Image
    display(Image(filename=outpath))
    
    




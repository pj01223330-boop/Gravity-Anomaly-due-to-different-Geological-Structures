def main():
    """
    Entry point — interactive menu loop.

    Main menu options
    -----------------
    [S]  Synthetic terrain  — choose one or all of six geological models,
         configure the grid and solver parameters, run both solvers and
         generate multi-panel comparison figures.

    [R]  Real data (NetCDF)  — load a .nc gravity file, apply Fourier
         upward continuation across the full 2-D grid, then validate a
         central cross-section against the explicit FD solver.

    [Q]  Quit.
    """
    print(_BANNER)

    # Ensure output directory exists
    outdir = r"C:\Users\PARUL\Downloads"
    os.makedirs(outdir, exist_ok=True)

    while True:
        print("\n" + "─" * 50)
        print("  MAIN MENU")
        print("─" * 50)
        print("  [S]  Synthetic terrain   (6 geological models)")
        print("  [R]  Real data           (NetCDF .nc file)")
        print("  [Q]  Quit")
        print("─" * 50)

        try:
            mode = input("\n  Choice: ").strip().upper()
        except (EOFError, KeyboardInterrupt):
            print("\n  Interrupted — exiting.")
            break

        if mode == "Q":
            print("  Goodbye.")
            break

        elif mode == "S":
            try:
                run_synthetic(outdir=outdir)
            except KeyboardInterrupt:
                print("\n  Synthetic run interrupted.")
            except Exception as exc:
                print(f"\n  ERROR during synthetic run: {exc}")
                import traceback
                traceback.print_exc()

        elif mode == "R":
            try:
                run_real(outdir=outdir)
            except KeyboardInterrupt:
                print("\n  Real-data run interrupted.")
            except Exception as exc:
                print(f"\n  ERROR during real-data run: {exc}")
                import traceback
                traceback.print_exc()

        else:
            print("  Unrecognised option.  Please enter S, R, or Q.")


if __name__ == "__main__":
    main()

# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 1 — TERRAIN GENERATOR
# ─────────────────────────────────────────────────────────────────────────────

class TerrainGenerator:
    """
    Synthesises geologically motivated 2-D density/topography models.

    generate(choice) → topography [m], density_contrast [kg m⁻³]
    """

    TERRAIN_TYPES = {
        "1": "Mid-Ocean Ridge with Transform Fault",
        "2": "Subduction Zone (Trench + Volcanic Arc)",
        "3": "Complex Impact Crater with Central Uplift",
        "4": "Subsurface Salt Dome Clusters (Negative Anomaly)",
        "5": "Sedimentary Basin",
        "6": "Continental Rift Valley",
    }

    def __init__(self, nx=128, ny=128, dx=1000.0, dy=1000.0, seed=42):
        self.nx, self.ny = nx, ny
        self.dx, self.dy = dx, dy
        self._rng = np.random.default_rng(seed)
        x = np.linspace(-1, 1, nx)
        y = np.linspace(-1, 1, ny)
        self.X, self.Y = np.meshgrid(x, y)

    def _fractal_noise(self, alpha=2.0):
        """1/f^alpha fractal noise (numpy FFT used for terrain generation only)."""
        raw = self._rng.standard_normal((self.ny, self.nx))
        rf  = np.fft.fft2(raw)
        kx  = np.fft.fftfreq(self.nx)
        ky  = np.fft.fftfreq(self.ny)
        KX, KY = np.meshgrid(kx, ky)
        K = np.sqrt(KX**2 + KY**2)
        K[0, 0] = 1e-10          # avoid division by zero at DC component
        out = np.real(np.fft.ifft2(rf / K**alpha))
        lo, hi = out.min(), out.max()
        return (out - lo) / (hi - lo + 1e-12)

    def generate(self, choice):
        """
        Generate topography and density contrast for the requested terrain.

        Parameters
        ----------
        choice : str   key from TERRAIN_TYPES

        Returns
        -------
        topo : ndarray (ny, nx)   height / thickness in metres
        rho  : float              density contrast in kg m⁻³
        """
        X, Y = self.X, self.Y
        base = self._fractal_noise()

        if choice == "1":
            print("  Synthesising Mid-Ocean Ridge with Transform Fault ...")
            shift = np.where(Y > 0, 0.20, -0.20)
            ridge = np.exp(-(X - shift)**2 / 0.02)
            topo  = (base * 500) + (ridge * 2500) - 4000
            rho   = 1500.0

        elif choice == "2":
            print("  Synthesising Subduction Zone ...")
            trench = -np.exp(-(X + 0.2)**2 / 0.01) * 3000
            arc    =  np.exp(-(X - 0.1)**2 / 0.04) * 4000
            topo   = (base * 800) + trench + arc - 2000
            rho    = 1800.0

        elif choice == "3":
            print("  Synthesising Complex Impact Crater ...")
            R      = np.sqrt(X**2 + Y**2)
            peak   =  np.exp(-R**2 / 0.005) * 1500
            floor_ = -np.exp(-R**2 / 0.050) * 1000
            rim    = np.sin(R * 15) * np.exp(-R**2 / 0.10) * 800
            topo   = (base * 300) + peak + floor_ + np.maximum(rim, 0)
            rho    = 2670.0

        elif choice == "4":
            print("  Synthesising Subsurface Salt Dome Clusters ...")
            topo = np.zeros((self.ny, self.nx))
            for _ in range(8):
                cx, cy = self._rng.uniform(-0.8, 0.8, 2)
                w = self._rng.uniform(0.005, 0.02)
                topo += np.exp(-((X - cx)**2 + (Y - cy)**2) / w) * 2000
            rho = -500.0          # salt is less dense than surrounding sediment

        elif choice == "5":
            print("  Synthesising Sedimentary Basin ...")
            basin = -np.exp(-(X**2 + Y**2) / 0.3) * 3000
            topo  = (base * 200) + basin
            rho   = -300.0

        elif choice == "6":
            print("  Synthesising Continental Rift Valley ...")
            rift      = -np.exp(-X**2 / 0.005) * 2000
            shoulders =  np.exp(-(np.abs(X) - 0.2)**2 / 0.01) * 1000
            topo  = (base * 400) + rift + shoulders
            rho   = 200.0

        else:
            raise ValueError(f"Unknown terrain choice: {choice!r}")

        return topo, rho


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 2 — BOUGUER GRAVITY  (infinite-slab forward model)
# ─────────────────────────────────────────────────────────────────────────────

_G = 6.67430e-11   # gravitational constant  [m³ kg⁻¹ s⁻²]


def bouguer_gravity(topography, rho):
    """
    Infinite-slab Bouguer approximation:
        Δg = 2π G ρ h  [m s⁻²]  ×10⁵  →  mGal

    Parameters
    ----------
    topography : ndarray   height / thickness in metres
    rho        : float     density contrast in kg m⁻³

    Returns
    -------
    gravity    : ndarray   Bouguer gravity anomaly in mGal
    """
    return 2.0 * np.pi * _G * rho * topography * 1e5


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 3 — FOURIER SPECTRAL SOLVER
# ─────────────────────────────────────────────────────────────────────────────

class FourierSolver:
    """
    Exact solution to Laplace's equation in free space (Sandwell 2002, eq. 12):

        Φ̂(k, z) = Φ̂(k, 0) · exp(−2π|k|z)

    |k| in cycles m⁻¹.  Uses numpy FFT — serves as the reference solution
    against which all FD results are validated.
    """

    def __init__(self, dx, dy):
        self.dx, self.dy = dx, dy

    def upward_continue_2d(self, surface, z):
        """
        Full 2-D upward continuation.

        Parameters
        ----------
        surface : ndarray (ny, nx)   surface gravity field in mGal
        z       : float              upward continuation height in metres

        Returns
        -------
        ndarray (ny, nx)  continued field
        """
        ny, nx = surface.shape
        kx = np.fft.fftfreq(nx, d=self.dx)
        ky = np.fft.fftfreq(ny, d=self.dy)
        KX, KY = np.meshgrid(kx, ky)
        K = np.sqrt(KX**2 + KY**2)
        return np.real(np.fft.ifft2(np.fft.fft2(surface) * np.exp(-2 * np.pi * K * z)))

    def upward_continue_1d(self, profile, z):
        """
        1-D upward continuation for cross-section comparison with FD.

        Parameters
        ----------
        profile : ndarray (nx,)   1-D surface gravity profile in mGal
        z       : float           upward continuation height in metres

        Returns
        -------
        ndarray (nx,)  continued profile
        """
        n  = len(profile)
        kx = np.fft.fftfreq(n, d=self.dx)
        K  = np.abs(kx)
        return np.real(np.fft.ifft(np.fft.fft(profile) * np.exp(-2 * np.pi * K * z)))


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 4 — FINITE DIFFERENCE SOLVER  (FULLY EXPLICIT — NO BUILT-INS)
# ─────────────────────────────────────────────────────────────────────────────

class FiniteDifferenceSolver:
    r"""
    Iterative solver for Laplace's equation  ∇²Φ = 0  in the (x, z)
    half-plane.  No scipy, no numpy.linalg — only direct array arithmetic.

    Discretisation (Farquharson & Mosher 2009, §2):

        [Φ(i+1,j) − 2Φ(i,j) + Φ(i−1,j)] / Δx²
      + [Φ(i,j+1) − 2Φ(i,j) + Φ(i,j−1)] / Δz²  = 0

    Setting α = Δx/Δz and solving for Φ(i,j):

        Φ(i,j) = w_x · (Φ(i+1,j) + Φ(i−1,j))
                + w_z · (Φ(i,j+1) + Φ(i,j−1))

        w_x = 1 / [2(1 + α²)],   w_z = α² / [2(1 + α²)]

    Boundary conditions:
        Φ[0,   :] = surface_bc    (Dirichlet — measured data at surface)
        Φ[nz-1,:] = 0             (Dirichlet — decay at far field)
        x-direction : periodic

    Available methods (all explicit — no built-in solvers):
    ----------------------------------------------------------
    "jacobi"       — Standard Jacobi update (ω forced = 1).
                     Unconditionally stable.  Slow O(n²) iterations.

    "rb_sor"       — Red-Black Successive Over-Relaxation.  [RECOMMENDED]
                     Domain partitioned into two interlocking checkerboard
                     sub-grids.  Odd-parity sites (red) updated first using
                     only even-parity (black) values, then black sites updated
                     with the fresh red values.
                     Stable for any ω ∈ (0, 2).
                     Optimal ω ≈ 2/(1 + sin(π/n)) ≈ 1.7–1.9 for large n.
                     Convergence: O(n) iters — roughly n× faster than Jacobi.

    "gauss_seidel" — Cell-by-cell Gauss-Seidel + SOR (mirrors Farquharson &
                     Mosher 2009 exactly).  Each node immediately uses the
                     freshest neighbour values.  Stable for ω ∈ (0, 2).
                     Pedagogically clearest; slower than rb_sor in Python.

    WHY NOT PLAIN JACOBI + ω>1?
    The Laplacian iteration matrix has eigenvalues in [−1, +1].  Applying
    ω>1 via JOR maps the eigenvalue near −1 to 1−ω(1−(−1)) = 1−2ω < −1
    (for ω>1), causing divergence.  Red-Black ordering separates the two
    sub-grids so each sub-grid's iteration matrix has only non-negative
    eigenvalues — over-relaxation is then unconditionally stable.
    """

    def __init__(self, nx, nz, dx, dz,
                 max_iter=6000, tol=1e-5, omega=1.7, method="rb_sor"):
        self.nx, self.nz = nx, nz
        self.dx, self.dz = dx, dz
        self.max_iter    = max_iter
        self.tol         = tol
        self.method      = method
        # Force omega = 1 for plain Jacobi (SOR is invalid there)
        self.omega = 1.0 if method == "jacobi" else float(omega)

        alpha     = dx / dz
        a2        = alpha ** 2
        self._wx  = 1.0 / (2.0 * (1.0 + a2))
        self._wz  = a2  / (2.0 * (1.0 + a2))

    # ── initial guess ─────────────────────────────────────────────────────────

    def _initial_guess(self, bc):
        """
        Linear interpolation from surface BC down to zero at the far-field BC.
        Converges significantly faster than initialising from zeros.
        """
        z_frac       = np.linspace(0.0, 1.0, self.nz)[:, None]   # (nz, 1)
        Phi          = bc[None, :] * (1.0 - z_frac)               # broadcast
        Phi[0,  :]   = bc          # enforce exact Dirichlet at surface
        Phi[-1, :]   = 0.0         # enforce decay at far field
        return Phi

    # ── sweep: Jacobi (omega = 1) ─────────────────────────────────────────────

    def _jacobi_sweep(self, Phi):
        """
        Standard Jacobi: all interior nodes updated simultaneously from
        values of the previous sweep.  ω = 1 is mandatory for stability.
        """
        wx, wz   = self._wx, self._wz
        Phi_int  = Phi[1:-1, :]
        left     = np.roll(Phi_int,  1, axis=1)   # i − 1  (periodic)
        right    = np.roll(Phi_int, -1, axis=1)   # i + 1  (periodic)
        above    = Phi[2:,  :]
        below    = Phi[:-2, :]

        new_int       = wx * (right + left) + wz * (above + below)
        delta         = new_int - Phi_int
        Phi[1:-1, :]  = new_int
        return Phi, float(np.max(np.abs(delta)))

    # ── sweep: Red-Black SOR (recommended) ───────────────────────────────────

    def _rb_sor_sweep(self, Phi):
        """
        Red-Black SOR — vectorised, stable for ω ∈ (0, 2).

        Two half-sweeps per iteration:
          Half 1 — update RED   nodes (i + j even) using BLACK neighbour values.
          Half 2 — update BLACK nodes (i + j odd)  using the fresh RED values.

        Because red nodes depend only on black nodes (and vice-versa), the
        checkerboard modes are decoupled and over-relaxation is safe.
        """
        wx, wz, omega = self._wx, self._wz, self.omega
        max_delta     = 0.0

        # Build checkerboard masks for interior rows only
        ii       = np.arange(self.nx)[None, :]           # shape (1, nx)
        jj       = np.arange(1, self.nz - 1)[:, None]   # shape (nz-2, 1)
        red_mask = ((ii + jj) % 2 == 0)                  # shape (nz-2, nx)

        for mask in (red_mask, ~red_mask):   # half-sweep 1 (red), then 2 (black)
            # Recompute neighbours after each half so black gets fresh red values
            left  = np.roll(Phi[1:-1, :],  1, axis=1)
            right = np.roll(Phi[1:-1, :], -1, axis=1)
            above = Phi[2:,  :]
            below = Phi[:-2, :]

            rhs           = wx * (right + left) + wz * (above + below)
            d             = omega * (rhs - Phi[1:-1, :]) * mask
            Phi[1:-1, :] += d
            max_delta      = max(max_delta, float(np.max(np.abs(d))))

        return Phi, max_delta

    # ── sweep: Gauss-Seidel scalar loop (mirrors Farquharson & Mosher) ───────

    def _gs_sweep(self, Phi):
        """
        Classic Gauss-Seidel + SOR.  Each node updated in-place so its fresh
        value is immediately used by subsequent nodes — exactly as in the
        cell-by-cell derivation of Farquharson & Mosher (2009, §2).
        Stable for ω ∈ (0, 2).  Slowest option due to pure Python loop.
        """
        wx, wz, omega = self._wx, self._wz, self.omega
        nx, nz        = self.nx, self.nz
        max_delta     = 0.0

        for j in range(1, nz - 1):
            for i in range(nx):
                il  = (i - 1) % nx           # periodic left neighbour
                ir  = (i + 1) % nx           # periodic right neighbour
                rhs = (wx * (Phi[j, ir] + Phi[j, il])
                       + wz * (Phi[j + 1, i] + Phi[j - 1, i]))
                d   = omega * (rhs - Phi[j, i])
                if abs(d) > max_delta:
                    max_delta = abs(d)
                Phi[j, i] += d

        return Phi, max_delta

    # ── public interface ──────────────────────────────────────────────────────

    def solve(self, surface_bc, verbose=True):
        """
        Solve Laplace's equation with Dirichlet BC at z = 0.

        Parameters
        ----------
        surface_bc : 1-D array, shape (nx,)   boundary condition at surface
        verbose    : bool   print iteration progress

        Returns
        -------
        Phi       : 2-D array (nz, nx)   solution Φ(x, z)
        residuals : list of float        max|ΔΦ| per iteration
        """
        Phi   = self._initial_guess(surface_bc)
        sweep = {
            "jacobi":       self._jacobi_sweep,
            "rb_sor":       self._rb_sor_sweep,
            "gauss_seidel": self._gs_sweep,
        }[self.method]

        residuals = []
        t0        = time.perf_counter()
        log_ev    = max(1, self.max_iter // 8)
        delta     = 1e99

        if verbose:
            m = self.method.replace("_", "-")
            print(f"    [{m}]  omega={self.omega:.3f}  tol={self.tol:.0e}  "
                  f"max_iter={self.max_iter}")

        for k in range(self.max_iter):
            Phi, delta = sweep(Phi)
            residuals.append(delta)

            if verbose and (k % log_ev == 0 or k < 3):
                elapsed = time.perf_counter() - t0
                print(f"      iter {k:5d}  |  max|DPhi| = {delta:.3e}  "
                      f"[{elapsed:.2f} s]")

            if delta < self.tol:
                if verbose:
                    elapsed = time.perf_counter() - t0
                    print(f"    ✓ Converged: iter={k + 1}  "
                          f"max|DPhi|={delta:.3e}  [{elapsed:.2f} s]")
                break
        else:
            elapsed = time.perf_counter() - t0
            if verbose:
                print(f"    ✗ Warning: max_iter={self.max_iter} reached.  "
                      f"Final max|DPhi|={delta:.3e}  [{elapsed:.2f} s]")

        return Phi, residuals

    def field_at_altitude(self, Phi, z):
        """
        Extract the field at a given height z by linear interpolation
        between the nearest discrete z-levels.

        Parameters
        ----------
        Phi : ndarray (nz, nx)   full FD solution
        z   : float              target altitude in metres

        Returns
        -------
        ndarray (nx,)
        """
        jf = z / self.dz
        j0 = int(jf)
        j1 = j0 + 1
        if j1 >= self.nz:
            return Phi[-1, :].copy()
        t = jf - j0
        return (1.0 - t) * Phi[j0, :] + t * Phi[j1, :]


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 5 — COMPARISON RUNNER
# ─────────────────────────────────────────────────────────────────────────────

def run_comparison(surface_profile, dx, z_target,
                   fd_nz=60, fd_tol=1e-5, fd_omega=1.7,
                   fd_method="rb_sor", fd_max_iter=6000):
    """
    Run both solvers on a 1-D surface profile and return a results dict.

    The FD domain spans z ∈ [0, 2·z_target] so the target altitude sits at
    the mid-point, comfortably away from both boundary conditions.

    Parameters
    ----------
    surface_profile : ndarray (nx,)   surface gravity in mGal
    dx              : float           grid spacing in metres
    z_target        : float           upward continuation height in metres
    fd_nz           : int             number of FD vertical levels
    fd_tol          : float           convergence tolerance
    fd_omega        : float           SOR relaxation factor
    fd_method       : str             "jacobi" | "rb_sor" | "gauss_seidel"
    fd_max_iter     : int             maximum FD iterations

    Returns
    -------
    dict with keys: fourier, fd, Phi_full, residuals, rms_err, max_err,
                    rel_pct, t_fourier, t_fd, method, tol, omega
    """
    nx = len(surface_profile)
    dz = 2.0 * z_target / (fd_nz - 1)

    print(f"\n  FD grid  : nx={nx}, nz={fd_nz}, dx={dx:.0f} m, dz={dz:.1f} m")
    print(f"  Domain   : Lx={nx * dx / 1e3:.1f} km, Lz={fd_nz * dz / 1e3:.1f} km")
    print(f"  Target z : {z_target / 1e3:.2f} km")

    # ── Fourier (reference) ────────────────────────────────────────────────
    t0       = time.perf_counter()
    fs       = FourierSolver(dx=dx, dy=dx)
    f_result = fs.upward_continue_1d(surface_profile, z_target)
    t_fourier = time.perf_counter() - t0
    print(f"\n  Fourier  →  {t_fourier * 1e3:.2f} ms")

    # ── Finite Difference ─────────────────────────────────────────────────
    print(f"\n  FD solver ({fd_method}) ...")
    t0 = time.perf_counter()
    fd = FiniteDifferenceSolver(
        nx=nx, nz=fd_nz, dx=dx, dz=dz,
        max_iter=fd_max_iter, tol=fd_tol,
        omega=fd_omega, method=fd_method,
    )
    Phi, residuals = fd.solve(surface_profile, verbose=True)
    fd_result      = fd.field_at_altitude(Phi, z_target)
    t_fd           = time.perf_counter() - t0
    print(f"  FD       →  {t_fd:.2f} s")

    # ── Error metrics ─────────────────────────────────────────────────────
    err     = fd_result - f_result
    rms_err = float(np.sqrt(np.mean(err**2)))
    max_err = float(np.max(np.abs(err)))
    sig_sd  = float(np.std(f_result)) + 1e-12
    rel_pct = rms_err / sig_sd * 100.0

    print("\n  Error (FD vs Fourier):")
    print(f"    RMS    : {rms_err:.4f} mGal")
    print(f"    Max    : {max_err:.4f} mGal")
    print(f"    Rel    : {rel_pct:.2f}% of signal sigma")
    if t_fourier > 0:
        print(f"    Speed  : Fourier is {t_fd / t_fourier:.0f}× faster")

    return dict(
        fourier=f_result, fd=fd_result, Phi_full=Phi,
        residuals=residuals,
        rms_err=rms_err, max_err=max_err, rel_pct=rel_pct,
        t_fourier=t_fourier, t_fd=t_fd,
        method=fd_method, tol=fd_tol, omega=fd_omega,
    )


# ─────────────────────────────────────────────────────────────────────────────
#  SECTION 6 — REAL DATA LOADER  (NetCDF)
# ─────────────────────────────────────────────────────────────────────────────

def load_real_netcdf(filepath, var_name=None, z_alt=10_000.0,
                     fd_method="rb_sor", fd_omega=1.7,
                     fd_nz=40, fd_tol=1e-4):
    """
    Load a gravity / geoid grid from a NetCDF file and run both solvers.

    Free datasets
    -------------
      topex.ucsd.edu/WWW_html/mar_grav.html    (marine free-air gravity)
      icgem.gfz-potsdam.de                     (global spherical harmonic models)
      ngdc.noaa.gov / ncei.noaa.gov            (NOAA NCEI collections)

    Parameters
    ----------
    filepath  : str    path to .nc file
    var_name  : str    variable to read (None → auto-detect)
    z_alt     : float  upward continuation altitude in metres
    fd_method : str    FD solver method
    fd_omega  : float  SOR relaxation factor
    fd_nz     : int    FD vertical levels
    fd_tol    : float  FD convergence tolerance

    Returns
    -------
    dict or None
    """
    try:
        import xarray as xr
    except ImportError:
        print("  xarray not installed.  Run:  pip install xarray netCDF4")
        return None

    if not os.path.exists(filepath):
        print(f"  File not found: {filepath}")
        return None

    print(f"\n  Loading: {filepath}")
    ds = xr.open_dataset(filepath)
    print(f"  Variables   : {list(ds.data_vars)}")
    print(f"  Coordinates : {list(ds.coords)}")

    # Auto-detect the gravity/geoid variable
    if var_name is None:
        for candidate in ["z", "gravity", "geoid", "anomaly",
                           "freeair", "bouguer", "grav", "h", "topo"]:
            if candidate in ds.data_vars:
                var_name = candidate
                break
        if var_name is None:
            var_name = list(ds.data_vars)[0]
        print(f"  Auto-detected variable: '{var_name}'")

    data = ds[var_name].values.astype(float)

    # Locate longitude / latitude coordinates
    lon = lat = None
    for n in ["lon", "longitude", "x"]:
        if n in ds.coords:
            lon = ds[n].values
            break
    for n in ["lat", "latitude", "y"]:
        if n in ds.coords:
            lat = ds[n].values
            break
    if lon is None or lat is None:
        print("  Cannot identify lon/lat coordinates.")
        return None

    print(f"  Shape  : {data.shape}   "
          f"range : {np.nanmin(data):.2f} … {np.nanmax(data):.2f}")

    # Replace NaN with field mean for solver BCs
    nan_mask   = np.isnan(data)
    data_clean = np.where(nan_mask, np.nanmean(data), data)

    dlat = float(np.abs(np.diff(lat).mean())) if len(lat) > 1 else 0.1
    dlon = float(np.abs(np.diff(lon).mean())) if len(lon) > 1 else 0.1
    dy   = dlat * 111_320.0
    dx   = dlon * 111_320.0 * np.cos(np.radians(float(np.mean(lat))))
    print(f"  Grid spacing: dx={dx / 1e3:.2f} km, dy={dy / 1e3:.2f} km")

    # Full 2-D Fourier continuation
    fs      = FourierSolver(dx=dx, dy=dy)
    fourier = fs.upward_continue_2d(data_clean, z_alt)
    fourier[nan_mask] = np.nan

    # 1-D FD comparison on the central row
    mid = data_clean.shape[0] // 2
    print(f"\n  FD comparison on central profile (row {mid}) ...")
    comp = run_comparison(
        data_clean[mid, :], dx=dx, z_target=z_alt,
        fd_nz=fd_nz, fd_tol=fd_tol, fd_omega=fd_omega, fd_method=fd_method,
    )

    return dict(
        lon=lon, lat=lat,
        surface=data, fourier_2d=fourier,
        mid_row=mid, comp=comp,
        dx=dx, dy=dy, z_alt=z_alt,
        var_name=var_name,
    )



def _ask(prompt, default):
    """Prompt for a string value; return default on empty input."""
    try:
        r = input(f"  {prompt} [{default}]: ").strip()
        return r if r else str(default)
    except EOFError:
        return str(default)


def _ask_float(prompt, default):
    """Prompt for a float; return default on empty or invalid input."""
    try:
        r = input(f"  {prompt} [{default}]: ").strip()
        return float(r) if r else float(default)
    except (ValueError, EOFError):
        return float(default)


def _ask_int(prompt, default):
    """Prompt for an integer; return default on empty or invalid input."""
    try:
        r = input(f"  {prompt} [{default}]: ").strip()
        return int(r) if r else int(default)
    except (ValueError, EOFError):
        return int(default)


def _ask_method():
    """Prompt the user to choose an FD iteration method."""
    print("\n  FD iteration methods:")
    print("    [1] rb_sor       — Red-Black SOR         [recommended]")
    print("    [2] jacobi       — Standard Jacobi (slow, omega fixed=1)")
    print("    [3] gauss_seidel — Gauss-Seidel + SOR   [slow in Python]")
    choice = _ask("Method", "1")
    return {"1": "rb_sor", "2": "jacobi", "3": "gauss_seidel"}.get(choice, "rb_sor")


